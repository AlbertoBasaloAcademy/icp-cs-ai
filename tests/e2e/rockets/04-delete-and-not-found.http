@AstroBookings_HostAddress = http://localhost:5070

# Deletes the existing rocket.
DELETE {{AstroBookings_HostAddress}}/rockets/1
Accept: application/json

###

# Verifies not found responses for missing rockets.
GET {{AstroBookings_HostAddress}}/rockets/1
Accept: application/json

