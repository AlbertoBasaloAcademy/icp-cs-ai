@AstroBookings_HostAddress = http://localhost:5070

# Rejects invalid range.
POST {{AstroBookings_HostAddress}}/cohetes/
Content-Type: application/json
Accept: application/json

{
  "nombre": "Bad Range",
  "alcance": "jupiter",
  "capacidad": 4
}

###

# Rejects invalid capacity.
POST {{AstroBookings_HostAddress}}/cohetes/
Content-Type: application/json
Accept: application/json

{
  "nombre": "Bad Capacity",
  "alcance": "mars",
  "capacidad": 11
}

###

# Rejects missing required name.
POST {{AstroBookings_HostAddress}}/cohetes/
Content-Type: application/json
Accept: application/json

{
  "nombre": "   ",
  "alcance": "suborbital",
  "capacidad": 2
}

###
